# Copy file này thành .env để chạy local
# Trên Render thì nhập trực tiếp vào Environment Variables

# Token bí mật — bạn tự đặt, điền y chang lên SePay dashboard
SEPAY_WEBHOOK_TOKEN=your_secret_token_here

# Firebase service account key (dạng JSON 1 dòng)
# Lấy từ: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Sau đó dùng lệnh bên dưới để chuyển thành 1 dòng:
#   cat serviceAccountKey.json | tr -d '\n'
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}
